# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ═══════════════════════════════════════════════════════════════════════════════
# Environment & secrets
# ═══════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.example
*.pem
*.key

# ═══════════════════════════════════════════════════════════════════════════════
# Logs & temporaries
# ═══════════════════════════════════════════════════════════════════════════════
*.log
tmp/
temp/

